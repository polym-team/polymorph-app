generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  profileImage String?  @map("profile_image")
  password     String?  // 추후 자체 가입 시 사용 (Argon2 해시)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  accounts            Account[]
  googleCalendarGrant GoogleCalendarGrant?

  @@map("users")
}

/**
 * 소셜 로그인 연결 정보 (provider별)
 * 같은 이메일로 Google + Kakao 로그인하면 같은 User에 Account 2개가 연결됨
 */
model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  provider          String   // google, kakao
  providerAccountId String   @map("provider_account_id")
  email             String?
  name              String?
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/**
 * 구글 캘린더 연동 grant (incremental authorization)
 * 로그인(openid/profile/email)과 분리된 별도 동의로 받은 calendar.events.readonly 권한.
 * refresh token 은 AES-256-GCM 으로 암호화해 저장하며, 브로커 API 외부로 절대 노출하지 않는다.
 * User 당 최대 1개(@unique userId).
 */
model GoogleCalendarGrant {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  refreshToken         String    @map("refresh_token") @db.Text // AES-256-GCM 암호문
  accessToken          String?   @map("access_token") @db.Text // AES-256-GCM 암호문 (캐시)
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")
  scopes               String    @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_calendar_grants")
}

/**
 * 등록된 클라이언트 앱
 * 각 앱별로 토큰 만료시간, 콜백 URL 등을 다르게 설정
 */
model ClientApp {
  id                   String   @id @default(cuid())
  clientId             String   @unique @map("client_id")
  name                 String
  allowedRedirectUris  String   @map("allowed_redirect_uris") @db.Text
  accessTokenLifetime  Int      @default(3600) @map("access_token_lifetime")
  refreshTokenLifetime Int      @default(2592000) @map("refresh_token_lifetime") // 30일
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("client_apps")
}

/**
 * OAuth 2.1 Authorization Code (PKCE)
 * /api/oauth/authorize 가 발급, /api/oauth/token 이 소비하는 단기 1회용 코드.
 * 평문 저장 금지: HMAC-SHA256(code, OAUTH_JWT_SECRET) 해시만 저장한다.
 */
model AuthorizationCode {
  id            String    @id @default(cuid())
  codeHash      String    @unique @map("code_hash")
  userId        String    @map("user_id")
  clientId      String    @map("client_id")
  redirectUri   String    @map("redirect_uri") @db.Text
  codeChallenge String    @map("code_challenge") // S256
  scope         String?   @db.Text
  expiresAt     DateTime  @map("expires_at") // 발급 후 60초
  usedAt        DateTime? @map("used_at") // 단일 사용 표시
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("authorization_codes")
}

/**
 * OAuth 2.1 Refresh Token (rotation)
 * opaque 랜덤값을 HMAC-SHA256(token, OAUTH_JWT_SECRET) 해시로만 저장.
 * 갱신 시 회전(revoke old + issue new); revokedAt 세팅 후에도 rotatedTo 로 재사용 탐지 가능.
 */
model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  clientId  String    @map("client_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  rotatedTo String?   @map("rotated_to") // 회전 시 새 토큰 id
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, clientId])
  @@map("refresh_tokens")
}
