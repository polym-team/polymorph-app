generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 입금 원장의 원본 레코드. 브릿지가 은행 SMS/알림을 파싱해 POST /api/deposits로 적재한다.
/// 원장은 매칭/소비 상태를 갖지 않는다(디커플링) — 소비 상태는 소비자(mall)가 소유.
model Deposit {
  id          Int      @id @default(autoincrement())
  externalId  String   @unique @map("external_id") @db.VarChar(191) // 멱등 키(브릿지 생성: 원문 해시 등)
  bankAccount String?  @map("bank_account") @db.VarChar(64)         // 수취 계좌(우리 계좌)
  payerName   String   @map("payer_name") @db.VarChar(191)          // 입금자명(원문)
  amount      Int                                                    // 입금액(원)
  balance     Int?                                                   // 잔액(파싱되면)
  txAt        DateTime @map("tx_at")                                 // 은행 거래 시각
  rawText     String   @map("raw_text") @db.Text                     // 원문(감사용)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([txAt])
  @@map("deposits")
}

/// API 접근 토큰. 발급 API로 생성하며 원문은 발급 시 1회만 노출, DB에는 SHA-256 해시로만 저장.
/// scope로 엔드포인트 권한 분리: ingest=POST /api/deposits, read=GET /api/deposits.
model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(191)                       // 사람이 식별할 라벨(예: "android-bridge", "mall")
  scope      String    @db.VarChar(16)                        // 'ingest' | 'read'
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64) // SHA-256 hex
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("api_tokens")
}

/// 사용자 소유 디바이스(브릿지 앱 설치 기기). oauth userId에 귀속.
/// 최초 설치 시 앱이 SSO 로그인 후 엔롤(POST /api/devices)로 생성.
model Device {
  id            Int       @id @default(autoincrement())
  userId        String    @map("user_id") @db.VarChar(191)   // oauth User.id(sub)
  name          String?   @db.VarChar(191)                    // 사용자 라벨(예: "매장 공기계")
  phoneNumber   String?   @map("phone_number") @db.VarChar(32) // 엔롤 시 보고(자동조회→실패시 수동)
  platform      String    @default("android") @db.VarChar(16)
  ingestTokenId Int?      @map("ingest_token_id")             // 등록 완료 시 발급된 ApiToken.id
  lastSeenAt    DateTime? @map("last_seen_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("devices")
}

/// 은행 입금알림 등록 세션. 웹에서 시작, 앱이 은행 OTP를 캡처해 릴레이, 웹에서 완료.
/// 상호배제: phoneNumber당 active(awaiting_otp) 세션 1개 — MariaDB partial unique 미지원이라
/// 앱 레벨(트랜잭션 내 체크)로 강제. @@index([phoneNumber, status])로 조회 최적화.
model RegistrationSession {
  id            Int       @id @default(autoincrement())
  userId        String    @map("user_id") @db.VarChar(191)
  deviceId      Int       @map("device_id")
  bank          String    @db.VarChar(32)
  accountKey    String?   @map("account_key") @db.VarChar(191) // 계좌 식별(선택)
  phoneNumber   String    @map("phone_number") @db.VarChar(32)  // 은행 폼에 입력할 번호(=디바이스 번호)
  status        String    @db.VarChar(24)                       // awaiting_otp | verified | expired | canceled
  otpCode       String?   @map("otp_code") @db.VarChar(16)      // 앱이 릴레이한 OTP(완료/만료 후 폐기)
  otpReceivedAt DateTime? @map("otp_received_at")
  expiresAt     DateTime  @map("expires_at")
  verifiedAt    DateTime? @map("verified_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([phoneNumber, status])
  @@index([deviceId])
  @@index([userId])
  @@map("registration_sessions")
}
