{
  "name": "@polym-team/element-inspector",
  "version": "0.1.0",
  "description": "Framework-agnostic, DOM read-only helpers for element inspection: box-model / gap measurement and tree traversal.",
  "license": "MIT",
  "sideEffects": false,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "tsc": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "5.7.2"
  }
}
